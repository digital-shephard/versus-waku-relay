# Pinned to the version proven by the Versus controlled Waku laboratory.
NWAKU_IMAGE=wakuorg/nwaku:v0.38.1
CADDY_IMAGE=caddy:2.10.0-alpine

# Unique public identity for this host.
PUBLIC_DOMAIN=relay-a.example.org
PUBLIC_IP=203.0.113.10
VERSUS_WAKU_NODE_KEY=replace_with_64_lowercase_hex_characters

# The other independently hosted Versus service node.
VERSUS_WAKU_STATIC_PEER=/dns4/relay-b.example.org/tcp/60000/p2p/replace_with_peer_id

# Versus network boundary. Do not silently change these in one node.
VERSUS_WAKU_CLUSTER_ID=66
VERSUS_WAKU_NUM_SHARDS=8

# Bounded temporary history, not permanent message storage.
VERSUS_WAKU_STORE_SECONDS=21600
VERSUS_WAKU_STORE_CAPACITY=25000
VERSUS_WAKU_STORE_SIZE=512MB

# Initial measured service tier. Revisit only with capacity evidence.
VERSUS_WAKU_MAX_CONNECTIONS=200
VERSUS_WAKU_IP_COLOCATION_LIMIT=20
VERSUS_WAKU_PEER_STORE_CAPACITY=1000
VERSUS_WAKU_FILTER_MAX_PEERS=250
VERSUS_WAKU_FILTER_MAX_CRITERIA=64

# Host-only operator endpoints.
VERSUS_WAKU_REST_PORT=18645
VERSUS_WAKU_METRICS_PORT=18008

# Paths may be absolute on a production host.
VERSUS_WAKU_DATA_DIR=./data
CADDY_DATA_DIR=./runtime/caddy-data
CADDY_CONFIG_DIR=./runtime/caddy-config
