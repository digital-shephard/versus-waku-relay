# Pinned to the version proven by the Versus controlled Waku laboratory.
NWAKU_IMAGE=wakuorg/nwaku:v0.38.1
CADDY_IMAGE=caddy:2.10.0-alpine

# Unique public identity for this host.
PUBLIC_DOMAIN=relay-a.example.org
PUBLIC_IP=203.0.113.10
VERSUS_WAKU_NODE_KEY=replace_with_64_lowercase_hex_characters

# The other independently hosted Versus service node.
VERSUS_WAKU_STATIC_PEER=/dns4/relay-b.example.org/tcp/60000/p2p/replace_with_peer_id

# Versus network boundary. Do not silently change these in one node.
VERSUS_WAKU_CLUSTER_ID=66
VERSUS_WAKU_NUM_SHARDS=8

# Bounded temporary history, not permanent message storage.
VERSUS_WAKU_STORE_SECONDS=21600
VERSUS_WAKU_STORE_CAPACITY=25000
VERSUS_WAKU_STORE_SIZE=512MB

# Initial measured service tier. Revisit only with capacity evidence.
VERSUS_WAKU_MAX_CONNECTIONS=200
VERSUS_WAKU_IP_COLOCATION_LIMIT=20
VERSUS_WAKU_PEER_STORE_CAPACITY=1000
VERSUS_WAKU_FILTER_MAX_PEERS=250
VERSUS_WAKU_FILTER_MAX_CRITERIA=64

# Host-only operator endpoints.
VERSUS_WAKU_REST_PORT=18645
VERSUS_WAKU_METRICS_PORT=18008

# Paths may be absolute on a production host.
VERSUS_WAKU_DATA_DIR=./data
CADDY_DATA_DIR=./runtime/caddy-data
CADDY_CONFIG_DIR=./runtime/caddy-config

# Full-node verification. Keep both secrets outside Git and use distinct
# non-funded attestor keys for independent nodes.
VERSUS_BASE_RPC_URL=https://base-mainnet.infura.io/v3/replace_me
VERSUS_CHAIN_ID=8453
VERSUS_ARENA_ADDRESS=0x0000000000000000000000000000000000000000
VERSUS_RAIN_ATTESTOR_PRIVATE_KEY=0xreplace_with_distinct_32_byte_private_key
VERSUS_RAIN_START_BLOCK=0
VERSUS_RAIN_POLL_MS=12000
VERSUS_RAIN_CONFIRMATIONS=2
VERSUS_RAIN_MAX_BLOCK_SPAN=2000
VERSUS_RAIN_DISTRIBUTION_MS=5000
VERSUS_RPC_DAILY_CREDIT_BUDGET=3000000
VERSUS_RPC_CREDITS_PER_SECOND=500
VERSUS_HATCH_QUOTE_ENABLED=true
VERSUS_HATCH_QUOTE_REFRESH_MS=60000
VERSUS_HATCH_QUOTE_FULL_SCAN_MS=600000
VERSUS_HATCH_QUOTE_VALID_MS=180000
VERSUS_HATCH_QUOTE_STALE_MS=900000
VERSUS_HATCH_QUOTE_BUFFER_BPS=300
VERSUS_NODE_DATA_DIR=./node-data
VERSUS_NODE_HEALTH_PORT=18787

# Optional permissionless graduation keeper. Disabled nodes still relay,
# verify, and publish rain normally. When enabled, use a separate funded EOA
# with only enough ETH for bounded Base transaction fees. Never reuse a Cypher
# owner, Waku transport, or rain-attestor key.
VERSUS_GRADUATION_ENABLED=false
VERSUS_GRADUATION_KEEPER_PRIVATE_KEY=
VERSUS_GRADUATION_SUBMISSION_DELAY_MS=0
VERSUS_GRADUATION_REBROADCAST_MS=120000
VERSUS_GRADUATION_MAX_GAS_LIMIT=8000000
VERSUS_GRADUATION_MAX_EXECUTION_FEE_WEI=5000000000000000
